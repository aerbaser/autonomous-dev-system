{
  "name": "autonomous-dev-system",
  "version": "0.1.0",
  "description": "Self-improving autonomous development system on Claude Agent SDK",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "autonomous-dev": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "nightly": "tsx src/index.ts nightly",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agent",
    "claude",
    "autonomous",
    "development"
  ],
  "license": "MIT",
  "overrides": {
    "@anthropic-ai/sdk": "^0.86.1"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.118",
    "@anthropic-ai/sdk": "^0.86.1",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^10.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5"
  }
}
