{
  "permissions": {
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -r :*)",
      "Bash(sudo:*)",
      "Bash(dd :*)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Edit(~/.ssh/*)",
      "Write(~/.ssh/*)"
    ],
    "ask": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(curl :*)",
      "Bash(npm publish:*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
